/* VS Code-inspired light theme */

QWidget {
    background-color: #f3f3f3;
    color: #333333;
    selection-background-color: #add6ff;
    selection-color: #000000;
    font-family: "Segoe UI";
    font-size: 9pt;
}

QMainWindow,
QDialog {
    background-color: #f3f3f3;
}

QFrame,
QGroupBox,
QTabWidget::pane,
QDockWidget,
QScrollArea,
QListWidget,
QTreeWidget,
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #d4d4d4;
}

QGroupBox {
    margin-top: 10px;
    padding-top: 12px;
    border-radius: 4px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
    color: #333333;
}

QLabel {
    background: transparent;
    color: #333333;
}

QTextEdit,
QPlainTextEdit,
QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QAbstractSpinBox,
QListWidget,
QTreeWidget,
QTableWidget {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #c8c8c8;
    border-radius: 3px;
}

QTextEdit,
QPlainTextEdit {
    padding: 6px;
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QAbstractSpinBox {
    min-height: 24px;
    padding: 2px 8px;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus,
QComboBox:focus,
QSpinBox:focus,
QDoubleSpinBox:focus,
QListWidget:focus,
QTreeWidget:focus,
QTableWidget:focus {
    border: 1px solid #007acc;
}

QPushButton {
    background-color: #007acc;
    color: #ffffff;
    border: 1px solid #006eb8;
    padding: 6px 12px;
    border-radius: 3px;
}

QPushButton:hover {
    background-color: #118adf;
}

QPushButton:pressed {
    background-color: #005f9e;
    border-color: #005f9e;
}

QPushButton:disabled {
    background-color: #d0d0d0;
    color: #8a8a8a;
    border-color: #d0d0d0;
}

QToolBar {
    background-color: #f3f3f3;
    border: none;
    border-bottom: 1px solid #dcdcdc;
    spacing: 6px;
    padding: 4px 6px;
}

QToolButton {
    background-color: transparent;
    color: #333333;
    border: 1px solid transparent;
    padding: 5px 8px;
    border-radius: 3px;
}

QToolButton:hover {
    background-color: #e8e8e8;
    border-color: #d4d4d4;
}

QToolButton:pressed {
    background-color: #dceeff;
}

QMenuBar {
    background-color: #ffffff;
    color: #333333;
    border-bottom: 1px solid #dcdcdc;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 10px;
}

QMenuBar::item:selected {
    background-color: #e8e8e8;
}

QMenu {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d4d4d4;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px 6px 10px;
    border-radius: 3px;
}

QMenu::item:selected {
    background-color: #cce8ff;
    color: #000000;
}

QMenu::separator {
    height: 1px;
    background: #d4d4d4;
    margin: 4px 8px;
}

QTabWidget::pane {
    top: -1px;
}

QTabBar::tab {
    background-color: #ececec;
    color: #555555;
    padding: 8px 14px;
    border: none;
    border-right: 1px solid #e0e0e0;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #000000;
}

QTabBar::tab:hover:!selected {
    background-color: #e2e2e2;
    color: #333333;
}

QStatusBar {
    background-color: #007acc;
    color: #ffffff;
    border-top: 1px solid #006eb8;
}

QStatusBar QLabel {
    background: transparent;
    color: #ffffff;
    padding: 0 6px;
}

QProgressBar {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #b8d9f1;
    border-radius: 3px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #007acc;
}

QScrollBar:vertical,
QScrollBar:horizontal {
    background-color: #f3f3f3;
    border: none;
    margin: 0;
}

QScrollBar:vertical {
    width: 12px;
}

QScrollBar:horizontal {
    height: 12px;
}

QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
    background-color: #c8c8c8;
    border-radius: 5px;
    min-height: 24px;
    min-width: 24px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
    background-color: #b6b6b6;
}

QScrollBar::add-line,
QScrollBar::sub-line,
QScrollBar::add-page,
QScrollBar::sub-page {
    background: none;
    border: none;
}

QSlider::groove:horizontal {
    height: 4px;
    background: #d0d0d0;
    border-radius: 2px;
}

QSlider::sub-page:horizontal {
    background: #007acc;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background: #4f4f4f;
    width: 12px;
    height: 12px;
    margin: -4px 0;
    border-radius: 6px;
}

QHeaderView::section {
    background-color: #f3f3f3;
    color: #333333;
    border: none;
    border-right: 1px solid #dcdcdc;
    border-bottom: 1px solid #dcdcdc;
    padding: 6px 8px;
}

QListWidget::item,
QTreeWidget::item,
QTableWidget::item {
    padding: 4px;
}

QListWidget::item:selected,
QTreeWidget::item:selected,
QTableWidget::item:selected {
    background-color: #cce8ff;
    color: #000000;
}

QSplitter::handle {
    background-color: #e0e0e0;
}

QSplitter::handle:hover {
    background-color: #007acc;
}

QCheckBox,
QRadioButton {
    spacing: 6px;
}

QCheckBox::indicator,
QRadioButton::indicator {
    width: 14px;
    height: 14px;
}

QCheckBox::indicator:unchecked,
QRadioButton::indicator:unchecked {
    background-color: #ffffff;
    border: 1px solid #888888;
}

QCheckBox::indicator:checked,
QRadioButton::indicator:checked {
    background-color: #007acc;
    border: 1px solid #007acc;
}
